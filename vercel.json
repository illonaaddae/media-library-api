{
  "version": 2,
  "builds": [
    { "src": "api/index.ts", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.+\\.(?:css|js|png|jpe?g|svg|ico|webp|woff2?|map))", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "api/index.ts" }
  ]
}
