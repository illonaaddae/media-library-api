# Copy to .env.development / .env.test / .env.production and fill in values.
# dotenv-flow loads the file matching NODE_ENV.

# development | test | production
NODE_ENV=
PORT=
# MongoDB connection string
DATABASE_URL=
# Reserved for the future auth extension (not used by the API yet)
JWT_SECRET=
# Max upload size in MEGABYTES (converted to bytes inside the config)
MAX_FILE_SIZE_MB=
# Directory Multer writes uploads to
UPLOAD_DIR=
# debug | info | warn | error
LOG_LEVEL=
